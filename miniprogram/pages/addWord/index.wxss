.form-card {
  margin-top: 32rpx;
  padding: 40rpx;
  border: 1rpx solid #e8e3dc;
  border-radius: 40rpx;
  background: #ffffff;
}

.field {
  margin-bottom: 32rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 500;
}

.field-label text {
  color: #f28b85;
}

.save-button {
  margin-top: 40rpx;
}
