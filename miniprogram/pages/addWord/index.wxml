<view class="rm-page">
  <view class="rm-topbar">
    <view class="rm-back" bindtap="goBack">‹</view>
    <view class="rm-top-title">添加单词</view>
    <view class="rm-icon-button">ⓘ</view>
  </view>

  <view class="form-card">
    <view class="field">
      <view class="field-label">俄语单词 <text>*</text></view>
      <input class="rm-input {{errors.russian_word ? 'error' : ''}}" placeholder="请输入俄语单词" placeholder-class="rm-input-placeholder" data-field="russian_word" bindinput="onInput" />
      <view class="field-error" wx:if="{{errors.russian_word}}">{{errors.russian_word}}</view>
    </view>
    <view class="field">
      <view class="field-label">中文意思 <text>*</text></view>
      <input class="rm-input {{errors.chinese_meaning ? 'error' : ''}}" placeholder="请输入中文意思" placeholder-class="rm-input-placeholder" data-field="chinese_meaning" bindinput="onInput" />
      <view class="field-error" wx:if="{{errors.chinese_meaning}}">{{errors.chinese_meaning}}</view>
    </view>
    <view class="field">
      <view class="field-label">词性（可选）</view>
      <input class="rm-input" placeholder="例：名词、动词、形容词" placeholder-class="rm-input-placeholder" data-field="part_of_speech" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="field-label">例句（可选）</view>
      <textarea class="rm-textarea" placeholder="请输入例句" placeholder-class="rm-input-placeholder" data-field="example" bindinput="onInput"></textarea>
    </view>
  </view>

  <button class="rm-primary-button save-button {{saving ? 'disabled' : ''}}" loading="{{saving}}" bindtap="saveWord">
    {{saving ? "保存中..." : "保存"}}
  </button>
</view>
