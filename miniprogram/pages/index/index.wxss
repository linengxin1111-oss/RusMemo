.home-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
}

.study-card {
  margin-top: 48rpx;
  padding: 40rpx;
  border: 1rpx solid #e8e3dc;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(17, 24, 39, 0.04);
}

.card-heading {
  color: #111827;
  font-size: 34rpx;
  font-weight: 600;
}

.study-main {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: conic-gradient(#a5c7e6 0deg 230deg, #f4efe8 230deg 360deg);
}

.ring-inner {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #ffffff;
}

.study-summary {
  flex: 1;
  margin-left: 42rpx;
}

.progress-number {
  color: #111827;
  font-size: 44rpx;
  font-weight: 600;
}

.total {
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 400;
}

.continue-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 164rpx;
  height: 64rpx;
  margin-top: 20rpx;
  border-radius: 32rpx;
  background: #a5c7e6;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 36rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #e8e3dc;
}

.mini-stat {
  text-align: center;
}

.mini-value {
  color: #111827;
  font-size: 32rpx;
  font-weight: 600;
}

.mini-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.entry-list {
  margin-top: 32rpx;
  overflow: hidden;
  border: 1rpx solid #e8e3dc;
  border-radius: 36rpx;
  background: #ffffff;
}

.entry-item {
  display: flex;
  align-items: center;
  min-height: 120rpx;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid #e8e3dc;
}

.entry-item:last-child {
  border-bottom: none;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #f4efe8;
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 600;
}

.entry-icon.primary {
  background: rgba(165, 199, 230, 0.2);
  color: #4f6f9f;
}

.entry-icon.success {
  background: rgba(184, 220, 194, 0.28);
  color: #4b8b63;
}

.entry-icon.error {
  background: rgba(242, 139, 133, 0.18);
  color: #c65a55;
}

.entry-copy {
  flex: 1;
  margin-left: 24rpx;
}

.entry-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 600;
}

.entry-desc,
.entry-meta {
  color: #6b7280;
  font-size: 24rpx;
}

.entry-desc {
  margin-top: 8rpx;
}

.entry-meta {
  flex-shrink: 0;
}
