page {
  min-height: 100vh;
  background: #f5f5f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page {
  padding: 72rpx 40rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 44rpx;
}

.eyebrow {
  margin-bottom: 12rpx;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 600;
}

.title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 20rpx;
  max-width: 560rpx;
  color: #6e6e73;
  font-size: 30rpx;
  line-height: 1.5;
}

.panel {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.label,
.meta-label {
  color: #6e6e73;
  font-size: 24rpx;
  line-height: 1.4;
}

.value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  word-break: break-all;
}

.badge {
  flex-shrink: 0;
  min-width: 116rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8e8ed;
  color: #6e6e73;
  font-size: 22rpx;
  text-align: center;
  box-sizing: border-box;
}

.badge-ready {
  background: rgba(0, 122, 255, 0.12);
  color: #007aff;
}

.badge-success {
  background: rgba(52, 199, 89, 0.14);
  color: #248a3d;
}

.badge-error {
  background: rgba(255, 59, 48, 0.12);
  color: #ff3b30;
}

.message {
  margin-top: 28rpx;
  color: #6e6e73;
  font-size: 28rpx;
  line-height: 1.55;
}

.primary-button {
  margin-top: 32rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 92rpx;
}

.primary-button::after {
  border: none;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.meta-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  word-break: break-all;
}

.collection {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-top: 1rpx solid #e8e8ed;
  font-size: 28rpx;
}

.collection:first-of-type {
  border-top: none;
}

.collection-state {
  color: #34c759;
  font-size: 24rpx;
}
