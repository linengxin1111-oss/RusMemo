<view class="page">
  <view class="hero">
    <view class="eyebrow">RusMemo</view>
    <view class="title">云开发配置</view>
    <view class="subtitle">完成环境连接、数据库集合初始化和 OpenID 验证。</view>
  </view>

  <view class="panel">
    <view class="row">
      <view>
        <view class="label">当前环境</view>
        <view class="value">{{env || "未配置"}}</view>
      </view>
      <view class="badge badge-{{status}}">{{status}}</view>
    </view>

    <view class="message">{{message}}</view>

    <button class="primary-button" loading="{{loading}}" bindtap="initCloud">
      初始化并验证
    </button>
  </view>

  <view class="panel" wx:if="{{openid}}">
    <view class="section-title">验证结果</view>
    <view class="meta">
      <view class="meta-label">OpenID</view>
      <view class="meta-value">{{openid}}</view>
    </view>
  </view>

  <view class="panel" wx:if="{{collections.length}}">
    <view class="section-title">数据库集合</view>
    <view class="collection" wx:for="{{collections}}" wx:key="name">
      <view>{{item.name}}</view>
      <view class="collection-state">{{item.created ? "已创建" : "已存在"}}</view>
    </view>
  </view>
</view>
