<view class="rm-page with-tab">
  <view class="home-header">
    <view>
      <view class="rm-title">你好，继续学习吧</view>
      <view class="rm-subtitle">每天进步一点点</view>
    </view>
  </view>

  <view class="study-card">
    <view class="card-heading">今日学习</view>
    <view class="study-main">
      <view class="ring">
        <view class="ring-inner"></view>
      </view>
      <view class="study-summary">
        <view class="progress-number"><text>32</text><text class="total"> / 50</text></view>
        <view class="rm-muted">已完成</view>
        <button class="continue-button" bindtap="goStudy">继续学习</button>
      </view>
    </view>
    <view class="stat-row">
      <view class="mini-stat" wx:for="{{stats}}" wx:key="label">
        <view class="mini-value">{{item.value}}</view>
        <view class="mini-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="entry-list">
    <view
      class="entry-item"
      wx:for="{{entries}}"
      wx:key="title"
      data-url="{{item.url}}"
      bindtap="openEntry"
    >
      <view class="entry-icon {{item.tone}}">{{index + 1}}</view>
      <view class="entry-copy">
        <view class="entry-title">{{item.title}}</view>
        <view class="entry-desc">{{item.desc}}</view>
      </view>
      <view class="entry-meta">{{item.meta}} ›</view>
    </view>
  </view>
</view>
