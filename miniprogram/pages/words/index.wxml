<view class="rm-page with-tab">
  <view class="words-header">
    <view class="rm-title">单词本</view>
    <view class="header-actions">
      <view class="rm-icon-button" bindtap="showSearchTip">⌕</view>
      <view class="rm-icon-button" bindtap="showMoreTip">⋯</view>
    </view>
  </view>

  <view class="tabs">
    <view
      class="tab {{activeTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="*this"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      {{item}}
    </view>
  </view>

  <view class="word-count">
    共 {{visibleWords.length}} 个单词
    <text class="mock-tip" wx:if="{{usingMock}}"> · 示例数据</text>
  </view>
  <view class="load-error" wx:if="{{loadError}}">{{loadError}}</view>

  <view class="rm-card loading-card" wx:if="{{loading}}">
    加载词库中...
  </view>

  <view class="rm-list" wx:elif="{{visibleWords.length}}">
    <view
      class="rm-list-item"
      wx:for="{{visibleWords}}"
      wx:key="russian"
      data-type="{{item.type}}"
      data-id="{{item._id}}"
      bindtap="openWord"
    >
      <view>
        <view class="rm-word">{{item.russian}}</view>
        <view class="rm-meaning">{{item.meaning}}</view>
      </view>
      <view class="word-side">
        <view class="rm-tag {{item.type === 'user' ? 'primary' : ''}}">{{item.tag}}</view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>

  <view class="rm-card rm-empty" wx:else>
    <view class="rm-empty-icon">＋</view>
    <view class="rm-empty-title">{{emptyTitle}}</view>
    <view class="rm-empty-desc">{{emptyDesc}}</view>
  </view>

  <button class="floating-add" bindtap="addWord">+ 添加单词</button>
</view>
