<view class="rm-page with-tab">
  <view class="rm-topbar">
    <view class="rm-back" bindtap="goBack">‹</view>
    <view class="rm-top-title">今日学习</view>
    <view class="progress-count">{{currentIndex + 1}} / {{total}}</view>
  </view>

  <view class="progress-track">
    <view class="progress-fill" style="width: {{progress}}%;"></view>
  </view>

  <block wx:if="{{question.type === 'choice'}}">
    <view class="question-card">
      <view class="question-tip">{{question.prompt}}</view>
      <view class="russian-word">{{question.russian}}</view>
      <view class="word-meta">{{question.meta}}</view>
    </view>

    <view class="choices">
      <view
        class="choice {{selectedKey === item.key ? 'selected' : ''}} {{checked && item.key === question.answer ? 'correct' : ''}} {{checked && selectedKey === item.key && item.key !== question.answer ? 'wrong' : ''}}"
        wx:for="{{question.choices}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectChoice"
      >
        <text class="choice-key">{{item.key}}.</text>
        <text>{{item.text}}</text>
        <text class="choice-check" wx:if="{{checked && item.key === question.answer}}">✓</text>
        <text class="choice-check" wx:elif="{{checked && selectedKey === item.key && item.key !== question.answer}}">×</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="input-panel main-input-panel">
      <view class="input-hint">{{question.prompt}}</view>
      <view class="chinese-word">{{question.chinese}}</view>
      <view class="answer-box active">
        <input
          class="answer-input"
          value="{{inputValue}}"
          placeholder="请输入俄语..."
          placeholder-class="rm-input-placeholder"
          maxlength="20"
          bindinput="onAnswerInput"
          disabled="{{checked}}"
        />
        <text class="counter">{{inputValue.length}} / 20</text>
      </view>
      <view class="tip">提示：{{question.hint}}</view>
    </view>
  </block>

  <view class="feedback {{isCorrect ? 'success' : 'error'}}" wx:if="{{checked}}">
    {{feedback}}
  </view>

  <view class="action-row" wx:if="{{question.type === 'input' && !checked}}">
    <button class="rm-secondary-button half" bindtap="markUnknown">不会</button>
    <button class="rm-primary-button half" bindtap="checkAnswer">检查</button>
  </view>

  <button class="rm-primary-button next-button" wx:elif="{{!checked}}" bindtap="checkAnswer">
    检查
  </button>

  <button class="rm-primary-button next-button" wx:else bindtap="nextQuestion">
    下一题
  </button>
</view>
