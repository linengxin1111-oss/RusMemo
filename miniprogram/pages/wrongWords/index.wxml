<view class="rm-page">
  <view class="rm-topbar">
    <view class="rm-back" bindtap="goBack">‹</view>
    <view class="rm-top-title">错词本</view>
    <view class="rm-icon-button">⌕</view>
  </view>

  <view class="tabs">
    <view
      class="tab {{activeFilter === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      data-value="{{item.value}}"
      bindtap="switchFilter"
    >
      {{item.label}}
    </view>
  </view>

  <view class="study-notice" wx:if="{{loadError}}">{{loadError}}</view>

  <view class="word-count">共 {{total}} 个单词</view>

  <view class="rm-empty" wx:if="{{loading}}">
    <view class="rm-empty-icon">···</view>
    <view class="rm-empty-title">正在读取错词</view>
    <view class="rm-empty-desc">根据你的答题记录整理需要复习的单词</view>
  </view>

  <view class="rm-empty" wx:elif="{{!words.length}}">
    <view class="rm-empty-icon">✓</view>
    <view class="rm-empty-title">暂时没有错词</view>
    <view class="rm-empty-desc">继续保持，答错的单词会自动出现在这里</view>
  </view>

  <view class="rm-list" wx:else>
    <view class="rm-list-item" wx:for="{{words}}" wx:key="_id">
      <view>
        <view class="rm-word">{{item.russian}}</view>
        <view class="rm-meaning">{{item.meaning}}</view>
      </view>
      <view class="wrong-count">{{item.count}}</view>
    </view>
  </view>

  <button class="rm-outline-button review-button" bindtap="reviewAll">重新学习全部</button>
</view>
